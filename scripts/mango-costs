#!/bin/bash
# mango-costs CLI companion
# Usage: mango-costs [show|status]

SESSIONS_JSON="$HOME/.openclaw/agents/main/sessions/sessions.json"
SESSIONS_DIR="$HOME/.openclaw/agents/main/sessions"

case "$1" in
  show|"")
    APP_BIN="/Applications/MangoCosts.app/Contents/MacOS/MangoCosts"
    if [ -x "$APP_BIN" ]; then
      nohup "$APP_BIN" > /dev/null 2>&1 &
    else
      echo "MangoCosts not found at $APP_BIN"
      echo "Run: cd ~/Projects/mango-costs && xcodebuild -scheme MangoCosts -configuration Debug build"
    fi
    ;;
  status)
    if [ ! -f "$SESSIONS_JSON" ]; then
      echo "❌ No sessions.json found at $SESSIONS_JSON"
      exit 1
    fi
    echo "🥭 Mango Costs"
    echo "──────────────────────────"
    python3 -c "
import json, sys, os, glob
from datetime import datetime, timezone

sessions_json = os.path.expanduser('$SESSIONS_JSON')
sessions_dir = os.path.expanduser('$SESSIONS_DIR')

# Current session from sessions.json
with open(sessions_json) as f:
    data = json.load(f)

live = data.get('agent:main:main', {})
cost = live.get('estimatedCostUsd', 0)
inp  = live.get('inputTokens', 0)
out  = live.get('outputTokens', 0)
tot  = live.get('totalTokens', 0)
ctx  = live.get('contextTokens', 1000000)
model = live.get('model', 'unknown')
started_ms = live.get('startedAt', 0)
started = datetime.fromtimestamp(started_ms / 1000, tz=timezone.utc)
now = datetime.now(tz=timezone.utc)
elapsed = int((now - started).total_seconds())
h, rem = divmod(elapsed, 3600)
m = rem // 60
duration = f'{h}h {m}m' if h > 0 else f'{m}m'

rag = '🟢' if cost < 0.10 else ('🟡' if cost < 0.50 else '🔴')
print(f'  Session Cost:  {rag} \${cost:.4f}')
print(f'  Tokens:        {inp:,} in / {out:,} out')
print(f'  Context:       {tot:,} / {ctx:,}')
print(f'  Model:         {model}')
print(f'  Duration:      {duration}')

# All-time totals
all_files = glob.glob(os.path.join(sessions_dir, '*.jsonl')) + \
            glob.glob(os.path.join(sessions_dir, '*.jsonl.reset.*'))
all_cost = 0.0
all_input = 0
all_output = 0
oldest = None

for path in all_files:
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except:
                    continue
                if entry.get('type') == 'session' and oldest is None:
                    ts = entry.get('timestamp', '')
                    try:
                        d = datetime.fromisoformat(ts.replace('Z', '+00:00'))
                        if oldest is None or d < oldest:
                            oldest = d
                    except:
                        pass
                if entry.get('type') == 'message':
                    msg = entry.get('message', {})
                    if msg.get('role') == 'assistant':
                        usage = msg.get('usage', {})
                        all_input += usage.get('input', 0)
                        all_output += usage.get('output', 0)
                        all_cost += (usage.get('cost') or {}).get('total', 0)
    except:
        pass

since = oldest.strftime('%b %d') if oldest else 'unknown'
print()
print(f'  All-time Cost: \${all_cost:.4f}  (since {since})')
print(f'  All-time Toks: {all_input:,} in / {all_output:,} out')
"
    ;;
  update)
    SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath('$0'))")"
    PROJECT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
    echo "🥭 Building MangoCosts..."
    xcodebuild -project "$PROJECT_DIR/MangoCosts.xcodeproj" \
      -scheme MangoCosts \
      -configuration Debug \
      build \
      CODE_SIGN_IDENTITY="" \
      CODE_SIGNING_REQUIRED=NO 2>&1 | grep -E "BUILD|error:|warning: Mango"

    BUILD_APP=$(find ~/Library/Developer/Xcode/DerivedData/MangoCosts-*/Build/Products/Debug/MangoCosts.app -maxdepth 0 2>/dev/null | head -1)
    if [ -z "$BUILD_APP" ]; then
      echo "❌ Build failed or app not found"
      exit 1
    fi

    echo "📦 Installing to /Applications..."
    pkill -x MangoCosts 2>/dev/null; sleep 0.5
    cp -R "$BUILD_APP" /Applications/MangoCosts.app
    echo "✅ Done! Run: mango-costs show"
    ;;
  *)
    echo "Usage: mango-costs <command>"
    echo ""
    echo "Commands:"
    echo "  show     Launch MangoCosts app"
    echo "  status   Print current usage to terminal"
    echo "  update   Rebuild from source and reinstall to /Applications"
    ;;
esac
