#!/bin/bash
# mango-costs CLI companion
# Usage: mango-costs [show|status]

SESSION_FILE="$HOME/.openclaw/agents/main/sessions/d2afa572-efd6-4ca4-9c6e-42ddb9051b8c.jsonl"

case "$1" in
  show|"")
    APP_BIN="/Applications/MangoCosts.app/Contents/MacOS/MangoCosts"
    if [ -x "$APP_BIN" ]; then
      nohup "$APP_BIN" > /dev/null 2>&1 &
    else
      echo "MangoCosts not found at $APP_BIN"
      echo "Run: cd ~/Projects/mango-costs && xcodebuild -scheme MangoCosts -configuration Debug build"
    fi
    ;;
  status)
    if [ ! -f "$SESSION_FILE" ]; then
      echo "❌ No session file found at $SESSION_FILE"
      exit 1
    fi
    echo "🥭 Mango Costs"
    echo "──────────────────────────"
    python3 -c "
import json, sys

session_file = '$SESSION_FILE'
total_cost = 0.0
total_input = 0
total_output = 0
model = 'claude-sonnet-4-6'
session_start = None
found_model = False

with open(session_file) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        if entry.get('type') != 'message':
            continue
        msg = entry.get('message', {})
        if msg.get('role') != 'assistant':
            continue
        if session_start is None:
            session_start = entry.get('timestamp')
        if not found_model and msg.get('model'):
            model = msg['model']
            found_model = True
        usage = msg.get('usage', {})
        total_input += usage.get('input', 0)
        total_output += usage.get('output', 0)
        cost = usage.get('cost', {})
        total_cost += cost.get('total', 0)

rag = '🟢' if total_cost < 0.10 else ('🟡' if total_cost < 0.50 else '🔴')
print(f'  Cost:    {rag} \${total_cost:.4f}')
print(f'  Input:   {total_input:,} tokens')
print(f'  Output:  {total_output:,} tokens')
print(f'  Model:   {model}')
print(f'  Started: {session_start or \"unknown\"}')
"
    ;;
  *)
    echo "Usage: mango-costs <command>"
    echo ""
    echo "Commands:"
    echo "  show     Bring MangoCosts app to front"
    echo "  status   Print current usage to terminal"
    ;;
esac
